{
  "info": {
    "name": "Look2Eat Unified API",
    "description": "Comprehensive Postman collection for Look2Eat loyalty platform covering all modules: Auth, Admin (Brands, Cashiers, Milestones, Dashboard), Outlets, Subscriptions/Credits, Cashier Actions, and Public Webhooks.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwt_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "Register Owner",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"brandName\": \"Pizza Palace\",\n  \"slug\": \"pizza-palace\",\n  \"name\": \"Rajendra Kumar\",\n  \"email\": \"owner@look2eat.com\",\n  \"password\": \"SecurePass123!\",\n  \"phone\": \"9876543210\"\n}"
            },
            "description": "Register a new owner account and brand. Automatically sets 'brandId' and 'slug' variables upon success.",
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/register-owner",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register-owner"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.brand) {",
                  "    if (jsonData.data.brand.id) {",
                  "        pm.collectionVariables.set(\"brandId\", jsonData.data.brand.id);",
                  "    }",
                  "    if (jsonData.data.brand.slug) {",
                  "        pm.collectionVariables.set(\"slug\", jsonData.data.brand.slug);",
                  "    }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "description": "Login as brand owner. Sets 'jwt_token' and 'brandId' variables upon success.",
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
                  "}",
                  "if (jsonData.user && jsonData.user.brandId) {",
                  "    pm.collectionVariables.set(\"brandId\", jsonData.user.brandId);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login (Cashier)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"9988776655\",\n  \"password\": \"SecurePass123!\",\n  \"outletId\": \"{{outletId}}\"\n}"
            },
            "description": "Login using Cashier specific credentials. Sets 'cashierJwt' variable upon success.",
            "url": {
              "raw": "{{baseUrl}}/api/v1/cashier/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "cashier",
                "login"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set(\"cashierJwt\", jsonData.data.token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Logged-in Owner Details",
          "request": {
            "method": "GET",
            "header": [],
            "description": "Retrieve details of the currently logged-in brand owner. Required role: OWNER.",
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "me"
              ]
            }
          }
        }
      ]
    },
