    {
      "name": "5. Cashier Actions",
      "item": [
        {
          "name": "Customer Lookup",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{cashierJwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "description": "Fetch a customer's coin wallet details, milestones, and newness. Sets 'walletId' variable.",
            "url": {
              "raw": "{{baseUrl}}/api/v1/cashier/customer/{{phone}}?brandId={{brandId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "cashier",
                "customer",
                "{{phone}}"
              ],
              "query": [
                {
                  "key": "brandId",
                  "value": "{{brandId}}"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.walletId) {",
                  "    pm.collectionVariables.set(\"walletId\", jsonData.data.walletId);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Request Customer OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerPhoneNumber\": \"{{phone}}\",\n  \"brandId\": \"{{brandId}}\"\n}"
            },
            "description": "Cashier triggers an OTP to customer phone number via WhatsApp for verification.",
            "url": {
              "raw": "{{baseUrl}}/api/v1/cashier/request-customer-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "cashier",
                "request-customer-otp"
              ]
            }
          }
        },
        {
          "name": "Verify Customer OTP",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerPhoneNumber\": \"{{phone}}\",\n  \"otp\": \"1234\",\n  \"brandId\": \"{{brandId}}\"\n}"
            },
            "description": "Verify customer's OTP to validate their session before allowing a redemption transaction.",
            "url": {
              "raw": "{{baseUrl}}/api/v1/cashier/verify-customer-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "cashier",
                "verify-customer-otp"
              ]
            }
          }
        },
        {
          "name": "Process Purchase",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{cashierJwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerPhoneNumber\": \"{{phone}}\",\n  \"brandId\": \"{{brandId}}\",\n  \"purchaseAmount\": 1000\n}"
            },
            "description": "Record a customer purchase and award them loyalty points based on coinRatio setting.",
            "url": {
              "raw": "{{baseUrl}}/api/v1/cashier/transaction/purchase",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "cashier",
                "transaction",
                "purchase"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.transactionId) {",
                  "    pm.collectionVariables.set(\"transactionId\", jsonData.data.transactionId);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Process Redemption",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{cashierJwt}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerPhoneNumber\": \"{{phone}}\",\n  \"brandId\": \"{{brandId}}\",\n  \"milestoneId\": \"{{milestoneId}}\",\n  \"purchaseAmount\": 500\n}"
            },
            "description": "Process customer reward redemption for cashback at a specific milestone (requires OTP validation first). Also registers a concurrent purchase.",
            "url": {
              "raw": "{{baseUrl}}/api/v1/cashier/transaction/redeem",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "cashier",
                "transaction",
                "redeem"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.redemptionTransactionId) {",
                  "    pm.collectionVariables.set(\"transactionId\", jsonData.data.redemptionTransactionId);",
                  "}"
                ]
              }
            }
          ]
        }
