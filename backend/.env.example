# Base application settings
PORT=4000
NODE_ENV="development"

# Prisma database connection
DATABASE_URL="postgresql://user:password@hostname:5432/neondb"
PRISMA_ACCELERATE_URL=""

# JWT configuration
JWT_SECRET="your-super-secret-jwt-key"
JWT_EXPIRES_IN="1d"

# Official WhatsApp API (Cloud API)
WHATSAPP_ACCESS_TOKEN="your-meta-access-token"
WHATSAPP_PHONE_NUMBER_ID="your-phone-id"
WHATSAPP_API_VERSION="v25.0"

# WhatsApp Formatted Templates
WHATSAPP_TEMPLATE_OTP="reward_otp"
WHATSAPP_TEMPLATE_FIRST_PURCHASE="first_time_points_earned"
WHATSAPP_TEMPLATE_PURCHASE="earned_points_only"
WHATSAPP_TEMPLATE_PURCHASE_REDEEM="earned_and_redeemed"
WHATSAPP_TEMPLATE_EXPIRY_WARNING="first_reminder"

# Cloudinary configuration (Brand Imagery)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# WhatsApp Webhook Verification (must match Meta Dashboard config)
WHATSAPP_VERIFY_TOKEN="your-webhook-verify-token"

# Public-facing web URL (used in WhatsApp loyalty links)
PUBLIC_WEB_URL="https://your-domain.com"
